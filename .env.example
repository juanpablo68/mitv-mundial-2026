# Supabase - cliente público
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY

# Supabase - solo servidor. No exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=TU_SUPABASE_SERVICE_ROLE_KEY

# Seguridad para cron de resultados. Debe ser un valor largo aleatorio.
# En Vercel Cron se enviará como Authorization: Bearer $CRON_SECRET si está configurado.
CRON_SECRET=CAMBIAR_POR_UN_SECRETO_LARGO

# Telegram Bot API - solo servidor
TELEGRAM_BOT_TOKEN=123456789:AA...
TELEGRAM_CHAT_ID=-1001234567890

# API de resultados
# Opciones: generic | api-football | mock
RESULTS_API_PROVIDER=generic
RESULTS_API_URL=https://api-proveedor.com/results/world-cup-2026
RESULTS_API_HEADER=Authorization
RESULTS_API_KEY=TU_API_KEY

# Solo si usas API-Football/API-Sports
RESULTS_API_LEAGUE_ID=
RESULTS_API_SEASON=2026
